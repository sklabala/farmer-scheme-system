# Environment configuration for Farmer Scheme System
# Replace placeholder values with your real credentials before deploying

# Server
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/farmer_scheme
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your_jwt_secret_here_please_change
JWT_REFRESH_SECRET=your_refresh_secret_here_please_change

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15005550006

# Cloudinary (or other cloud storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# TTS Services
TTS_PROVIDER=aws
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1

# External APIs
PMKISAN_API_URL=https://pmkisan.gov.in/api
MYSCHME_API_URL=https://myscheme.gov.in/api

# Other
# Add any other environment variables required by the project here
